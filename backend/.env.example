# Backend API configuration
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Local storage. Relative paths resolve from the project root.
DATA_DIR=data
DB_PATH=data/freetown.db
UPLOAD_DIR=data/uploads

# Direct model provider configuration.
# Supported values:
# - none
# - openai_compatible
# - nvidia
# - anthropic
# - legacy_n8n
MODEL_PROVIDER_TYPE=none
MODEL_PROVIDER_MODEL=
MODEL_PROVIDER_TIMEOUT_MS=30000
MODEL_PROVIDER_MAX_TOKENS=800

# Optional generic provider settings.
# For openai_compatible, base URL defaults to https://api.openai.com/v1.
# For nvidia, base URL defaults to https://integrate.api.nvidia.com/v1.
# For anthropic, base URL defaults to https://api.anthropic.com/v1.
MODEL_PROVIDER_BASE_URL=

# You can provide the API key directly or point at another env var name.
MODEL_PROVIDER_API_KEY=
MODEL_PROVIDER_API_KEY_ENV_VAR=

# Anthropic-specific setting. Only used when MODEL_PROVIDER_TYPE=anthropic.
ANTHROPIC_VERSION=2023-06-01

# Optional legacy transition path.
# Keep empty unless you explicitly want to retain the old n8n bridge.
LEGACY_N8N_CHAT_WEBHOOK_URL=

# Example provider-specific secret env vars.
OPENAI_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=

# Embedding provider configuration.
# Supported values: nvidia, mistral, local.
EMBEDDING_PROVIDER=local
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_TIMEOUT_MS=30000
EMBEDDING_BATCH_SIZE=32
# Optional provider-specific JSON merged into /embeddings request bodies.
EMBEDDING_EXTRA_JSON=

# Optional Supabase/pgvector integration.
# SQLite remains the local cache and fallback store.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Security controls are opt-in for the local pilot.
ENABLE_DOCUMENT_ENCRYPTION=false
DOCUMENT_ENCRYPTION_KEY=
ENABLE_AUDIT_LOG=false
ENABLE_PROMPT_GUARD=false
ENABLE_OUTPUT_GUARD=false
ENABLE_CONTENT_FILTER=false
CONTENT_FILTER_BLACKLIST=
ENABLE_RATE_LIMIT=false
QUERY_RATE_LIMIT_PER_HOUR=100
ENABLE_SESSION_INACTIVITY_TIMEOUT=false
SESSION_INACTIVITY_MINUTES=30
ENABLE_LOGIN_LOCKOUT=false
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_MINUTES=15
ENABLE_DATA_RETENTION=false
MODEL_PROVIDER_RETRY_COUNT=3
SECURITY_REPORT_DIR=data/security-reports

# Required only when saving API keys through the admin API configuration panel.
API_CONFIG_ENCRYPTION_KEY=

# Local bootstrap only. Do not commit real passwords.
ADMIN_EMAIL=admin@example.local
ADMIN_NAME=Policy Intelligence Admin
ADMIN_PASSWORD=change-this-local-password
ADMIN_ROLE=admin
