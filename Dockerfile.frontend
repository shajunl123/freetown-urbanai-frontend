FROM node:22-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_POLICY_API_BASE_URL=http://localhost:3001/api
ENV VITE_POLICY_API_BASE_URL=$VITE_POLICY_API_BASE_URL

RUN npm run build:frontend

FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
