{
  "name": "freetown-urbanai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "npm run dev:backend & npm run dev:frontend",
    "backend:start": "npm --prefix backend run start:src",
    "db:init": "npm --prefix backend run db:init",
    "bootstrap:admin": "npm --prefix backend run bootstrap:admin",
    "seed:demo": "npm --prefix backend run seed:demo",
    "reindex": "npm --prefix backend run reindex",
    "test:backend": "npm --prefix backend test",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "build": "vite build",
    "build:frontend": "vite build",
    "build:backend": "npm --prefix backend run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "validate": "npm run typecheck:backend && npm run test:backend && npm run build:all",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "^0.181.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@google/genai": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
